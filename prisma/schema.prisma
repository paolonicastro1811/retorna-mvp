generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id                     String              @id @default(cuid())
  name                   String
  phone                  String?
  timezone               String              @default("America/Sao_Paulo")
  attributionWindowDays  Int                 @default(30) @map("attribution_window_days")
  createdAt              DateTime            @default(now()) @map("created_at")
  updatedAt              DateTime            @updatedAt @map("updated_at")
  plan                   String              @default("manual")
  discountFrequente      Int                 @default(5) @map("discount_frequente")
  discountOuro           Int                 @default(15) @map("discount_ouro")
  discountPrata          Int                 @default(10) @map("discount_prata")
  reactivationAfterDays  Int                 @default(30) @map("reactivation_after_days")
  streakTargetVisits     Int                 @default(3) @map("streak_target_visits")
  streakWindowDays       Int                 @default(7) @map("streak_window_days")
  surpriseEveryMaxVisits Int                 @default(7) @map("surprise_every_max_visits")
  surpriseEveryMinVisits Int                 @default(3) @map("surprise_every_min_visits")
  tierFrequenteMinVisits Int                 @default(3) @map("tier_frequente_min_visits")
  tierOuroMinVisits      Int                 @default(25) @map("tier_ouro_min_visits")
  tierPrataMinVisits     Int                 @default(10) @map("tier_prata_min_visits")
  roomLayout             Json?               @map("room_layout")
  avgMealDurationMinutes Int                 @default(90) @map("avg_meal_duration_minutes")
  waAccessToken          String?             @map("wa_access_token")
  waTokenExpiresAt       DateTime?           @map("wa_token_expires_at")
  waConnectedAt          DateTime?           @map("wa_connected_at")
  waPhoneNumber          String?             @map("wa_phone_number")
  waPhoneNumberId        String?             @map("wa_phone_number_id")
  wabaId                 String?             @map("waba_id")
  billingCycle           String              @default("monthly") @map("billing_cycle")
  stripeCustomerId       String?             @unique @map("stripe_customer_id")
  stripePriceId          String?             @map("stripe_price_id")
  stripeSubscriptionId   String?             @unique @map("stripe_subscription_id")
  subscriptionStatus     String              @default("trialing") @map("subscription_status")
  trialDays              Int                 @default(30) @map("trial_days")
  trialStartDate         DateTime?           @map("trial_start_date")
  automationLogs         AutomationLog[]
  campaigns              Campaign[]
  conversationReplies    ConversationReply[]
  customers              Customer[]
  importJobs             ImportJob[]
  inboundMessages        InboundMessage[]
  templates              MessageTemplate[]
  reservations           Reservation[]
  hours                  RestaurantHours[]
  tables                 RestaurantTable[]
  users                  User[]

  @@map("restaurants")
}

model RestaurantTable {
  id           String        @id @default(cuid())
  restaurantId String        @map("restaurant_id")
  tableNumber  Int           @map("table_number")
  seats        Int
  isActive     Boolean       @default(true) @map("is_active")
  height       Float?        @default(10)
  label        String?
  posX         Float?        @map("pos_x")
  posY         Float?        @map("pos_y")
  width        Float?        @default(10)
  reservations Reservation[]
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, tableNumber])
  @@index([restaurantId])
  @@map("restaurant_tables")
}

model RestaurantHours {
  id           String     @id @default(cuid())
  restaurantId String     @map("restaurant_id")
  dayOfWeek    Int        @map("day_of_week")
  openTime     String     @map("open_time")
  closeTime    String     @map("close_time")
  isClosed     Boolean    @default(false) @map("is_closed")
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, dayOfWeek])
  @@index([restaurantId])
  @@map("restaurant_hours")
}

model Customer {
  id                     String                    @id @default(cuid())
  restaurantId           String                    @map("restaurant_id")
  phone                  String
  name                   String?
  lifecycleStatus        String                    @default("active") @map("lifecycle_status")
  totalVisits            Int                       @default(0) @map("total_visits")
  totalSpent             Float                     @default(0) @map("total_spent")
  avgTicket              Float                     @default(0) @map("avg_ticket")
  lastVisitAt            DateTime?                 @map("last_visit_at")
  isFrequent             Boolean                   @default(false) @map("is_frequent")
  isHighSpender          Boolean                   @default(false) @map("is_high_spender")
  lastReactivatedAt      DateTime?                 @map("last_reactivated_at")
  createdAt              DateTime                  @default(now()) @map("created_at")
  updatedAt              DateTime                  @updatedAt @map("updated_at")
  contactableStatus      String                    @default("contactable") @map("contactable_status")
  whatsappOptInAt        DateTime?                 @map("whatsapp_opt_in_at")
  whatsappOptInStatus    String                    @default("unknown") @map("whatsapp_opt_in_status")
  acquisitionSource      String?                   @map("acquisition_source")
  welcomeAutoReplySentAt DateTime?                 @map("welcome_auto_reply_sent_at")
  marketingNudgeSentAt   DateTime?                 @map("marketing_nudge_sent_at")
  marketingOptInAt       DateTime?                 @map("marketing_opt_in_at")
  lastVisitAmount        Float?                    @map("last_visit_amount")
  birthday               DateTime?                 @db.Date
  currentStreak          Int                       @default(0) @map("current_streak")
  lastReactivationSentAt DateTime?                 @map("last_reactivation_sent_at")
  nextSurpriseAt         Int                       @default(5) @map("next_surprise_at")
  streakUpdatedAt        DateTime?                 @map("streak_updated_at")
  surpriseCounter        Int                       @default(0) @map("surprise_counter")
  tier                   String                    @default("novo")
  tierUpgradedAt         DateTime?                 @map("tier_upgraded_at")
  deletedAt              DateTime?                 @map("deleted_at")
  automationLogs         AutomationLog[]
  audienceItems          CampaignAudienceItem[]
  conversationReplies    ConversationReply[]
  events                 CustomerEvent[]
  restaurant             Restaurant                @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  inboundMessages        InboundMessage[]
  messages               OutboundMessage[]
  attributions           ReactivationAttribution[]
  reservations           Reservation[]

  @@unique([restaurantId, phone])
  @@index([restaurantId])
  @@index([restaurantId, lifecycleStatus])
  @@index([restaurantId, isFrequent])
  @@index([restaurantId, isHighSpender])
  @@index([restaurantId, whatsappOptInStatus])
  @@map("customers")
}

model CustomerEvent {
  id           String                   @id @default(cuid())
  customerId   String                   @map("customer_id")
  restaurantId String                   @map("restaurant_id")
  eventType    String                   @default("visit") @map("event_type")
  amount       Float?
  occurredAt   DateTime                 @map("occurred_at")
  createdAt    DateTime                 @default(now()) @map("created_at")
  customer     Customer                 @relation(fields: [customerId], references: [id], onDelete: Cascade)
  attribution  ReactivationAttribution?

  @@index([customerId])
  @@index([restaurantId, occurredAt])
  @@map("customer_events")
}

model Campaign {
  id           String                 @id @default(cuid())
  restaurantId String                 @map("restaurant_id")
  name         String
  status       String                 @default("draft")
  segmentRules Json                   @map("segment_rules")
  templateId   String?                @map("template_id")
  scheduledAt  DateTime?              @map("scheduled_at")
  startedAt    DateTime?              @map("started_at")
  completedAt  DateTime?              @map("completed_at")
  createdAt    DateTime               @default(now()) @map("created_at")
  updatedAt    DateTime               @updatedAt @map("updated_at")
  audience     CampaignAudienceItem[]
  restaurant   Restaurant             @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  template     MessageTemplate?       @relation(fields: [templateId], references: [id])
  messages     OutboundMessage[]

  @@index([restaurantId])
  @@index([restaurantId, status])
  @@map("campaigns")
}

model CampaignAudienceItem {
  id         String   @id @default(cuid())
  campaignId String   @map("campaign_id")
  customerId String   @map("customer_id")
  createdAt  DateTime @default(now()) @map("created_at")
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([campaignId, customerId])
  @@index([campaignId])
  @@map("campaign_audience_items")
}

model MessageTemplate {
  id              String     @id @default(cuid())
  restaurantId    String     @map("restaurant_id")
  name            String
  body            String
  channel         String     @default("whatsapp")
  isActive        Boolean    @default(true) @map("is_active")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  hsmLanguage     String     @default("pt_BR") @map("hsm_language")
  hsmTemplateName String?    @map("hsm_template_name")
  campaigns       Campaign[]
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@map("message_templates")
}

model OutboundMessage {
  id              String                   @id @default(cuid())
  campaignId      String                   @map("campaign_id")
  customerId      String                   @map("customer_id")
  restaurantId    String                   @map("restaurant_id")
  phone           String
  body            String
  status          String                   @default("queued")
  providerMsgId   String?                  @unique @map("provider_msg_id")
  sentAt          DateTime?                @map("sent_at")
  deliveredAt     DateTime?                @map("delivered_at")
  readAt          DateTime?                @map("read_at")
  failedAt        DateTime?                @map("failed_at")
  failReason      String?                  @map("fail_reason")
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")
  hsmLanguage     String?                  @map("hsm_language")
  hsmTemplateName String?                  @map("hsm_template_name")
  events          MessageEvent[]
  campaign        Campaign                 @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer        Customer                 @relation(fields: [customerId], references: [id], onDelete: Cascade)
  attribution     ReactivationAttribution?

  @@index([campaignId])
  @@index([customerId])
  @@index([restaurantId, status])
  @@index([providerMsgId])
  @@map("outbound_messages")
}

model MessageEvent {
  id        String          @id @default(cuid())
  messageId String          @map("message_id")
  eventType String          @map("event_type")
  payload   Json?
  createdAt DateTime        @default(now()) @map("created_at")
  message   OutboundMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("message_events")
}

model ReactivationAttribution {
  id         String          @id @default(cuid())
  messageId  String          @unique @map("message_id")
  customerId String          @map("customer_id")
  visitId    String          @unique @map("visit_id")
  revenue    Float
  createdAt  DateTime        @default(now()) @map("created_at")
  customer   Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  message    OutboundMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  visit      CustomerEvent   @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([messageId])
  @@map("reactivation_attributions")
}

model InboundMessage {
  id           String     @id @default(cuid())
  restaurantId String     @map("restaurant_id")
  customerId   String     @map("customer_id")
  phoneE164    String     @map("phone_e164")
  messageText  String?    @map("message_text")
  receivedAt   DateTime   @map("received_at")
  source       String     @default("whatsapp")
  createdAt    DateTime   @default(now()) @map("created_at")
  customer     Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([restaurantId, receivedAt])
  @@map("inbound_messages")
}

model ConversationReply {
  id           String     @id @default(cuid())
  restaurantId String     @map("restaurant_id")
  customerId   String     @map("customer_id")
  phoneE164    String     @map("phone_e164")
  messageText  String     @map("message_text")
  intent       String?
  sentAt       DateTime   @map("sent_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  customer     Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([restaurantId, sentAt])
  @@map("conversation_replies")
}

model Reservation {
  id           String           @id @default(cuid())
  restaurantId String           @map("restaurant_id")
  customerId   String?          @map("customer_id")
  customerName String?          @map("customer_name")
  phone        String
  tableId      String?          @map("table_id")
  date         DateTime         @db.Date
  time         String
  endTime      String?          @map("end_time")
  partySize    Int              @default(2) @map("party_size")
  status       String           @default("pending")
  notes        String?
  source       String           @default("manual")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  seatedAt     DateTime?        @map("seated_at")
  customer     Customer?        @relation(fields: [customerId], references: [id])
  restaurant   Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  table        RestaurantTable? @relation(fields: [tableId], references: [id])

  @@index([restaurantId, date])
  @@index([restaurantId, status])
  @@index([customerId])
  @@map("reservations")
}

model ImportJob {
  id            String     @id @default(cuid())
  restaurantId  String     @map("restaurant_id")
  status        String     @default("pending")
  fileName      String?    @map("file_name")
  totalRows     Int        @default(0) @map("total_rows")
  processedRows Int        @default(0) @map("processed_rows")
  errorRows     Int        @default(0) @map("error_rows")
  errors        Json?
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@map("import_jobs")
}

model AutomationLog {
  id            String     @id @default(cuid())
  restaurantId  String     @map("restaurant_id")
  customerId    String     @map("customer_id")
  templateKey   String     @map("template_key")
  status        String     @default("sent")
  providerMsgId String?    @map("provider_msg_id")
  metadata      Json?
  createdAt     DateTime   @default(now()) @map("created_at")
  customer      Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, templateKey])
  @@index([customerId])
  @@index([restaurantId, createdAt])
  @@map("automation_logs")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String?    @map("password_hash")
  name         String?
  restaurantId String     @map("restaurant_id")
  role         String     @default("owner")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@map("users")
}

model MagicLinkToken {
  id        String    @id @default(cuid())
  token     String    @unique
  email     String
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([token])
  @@index([email])
  @@map("magic_link_tokens")
}
