DATABASE_URL="postgresql://postgres:postgres@localhost:5432/reactivation_mvp"
PORT=3000

# ── Security ────────────────────────────────────────────
# API key for dashboard → backend auth (leave empty to disable)
API_KEY=
# CORS allowed origins (comma-separated, defaults to localhost)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Auth (Magic Link) ───────────────────────────────────
# Secret for signing JWTs — MUST change in production!
JWT_SECRET=change_me_to_a_random_64_char_string
# Session duration (default 30 days)
JWT_EXPIRES_IN=30d
# Magic link expiry in minutes (default 15)
MAGIC_LINK_EXPIRES_MINUTES=15
# App URL (frontend) — used to build magic link URLs
APP_URL=http://localhost:5173

# ── Email (Resend) ──────────────────────────────────────
# If not set, magic links are logged to console (dev mode)
# Sign up at resend.com → get API key
RESEND_API_KEY=your_resend_api_key_here
# Sender address (use onboarding@resend.dev for testing, your domain in production)
EMAIL_FROM="Retorna <onboarding@resend.dev>"

# ── Stripe Billing ──────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# Create 4 prices in Stripe Dashboard, then paste IDs here:
STRIPE_PRICE_MANUAL_MONTHLY=price_xxx
STRIPE_PRICE_MANUAL_ANNUAL=price_xxx
STRIPE_PRICE_AUTOMATIC_MONTHLY=price_xxx
STRIPE_PRICE_AUTOMATIC_ANNUAL=price_xxx

# ── AI Layout Generator ─────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Facebook App (WhatsApp Embedded Signup) ─────────────
FB_APP_ID=your_facebook_app_id
FB_APP_SECRET=your_facebook_app_secret

# ── WhatsApp Webhook Verification ──────────────────────
# Webhook verification token — you choose this value.
# Must match what you paste in Meta App Dashboard → Webhooks → Verify Token.
META_VERIFY_TOKEN=brasil_restaurante_verify_2026
# META_APP_SECRET is optional but recommended for signature verification
# META_APP_SECRET=your_meta_app_secret

# DEPRECATED: Global WhatsApp config (now per-restaurant via Embedded Signup)
# These are kept as optional fallback only. New restaurants should use
# the /whatsapp/connect endpoint with Embedded Signup instead.
# META_ACCESS_TOKEN=your_meta_access_token_here
# META_PHONE_NUMBER_ID=your_phone_number_id_here
