DATABASE_URL="postgresql://postgres:postgres@localhost:5432/reactivation_mvp"
PORT=3000

# ── Security ────────────────────────────────────────────
# API key for dashboard → backend auth (leave empty to disable)
API_KEY=
# CORS allowed origins (comma-separated, defaults to localhost)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── AI Layout Generator ─────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Meta WhatsApp Cloud API ──────────────────────────────
# All three are required for real webhook integration.

# Webhook verification token — you choose this value.
# Must match what you paste in Meta App Dashboard → Webhooks → Verify Token.
META_VERIFY_TOKEN=brasil_restaurante_verify_2026

# System User access token from Meta Business Manager.
# Business Manager → System Users → Generate Token → select WhatsApp app → whatsapp_business_messaging permission.
META_ACCESS_TOKEN=your_meta_access_token_here

# Phone Number ID from Meta App Dashboard → WhatsApp → API Setup.
# This is the ID of your business WhatsApp number (NOT the phone number itself).
META_PHONE_NUMBER_ID=your_phone_number_id_here
